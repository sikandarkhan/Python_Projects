import random

stored_pin = str(random.randint(1000, 9999))
balance = 1000

print("Welcome to ATM Simulator")
print("Your generated PIN is:", stored_pin)  # for testing (remove in final submission if needed)

def check_pin():
    pin = input("Enter your PIN: ")
    return pin == stored_pin

def change_pin():
    global stored_pin
    old_pin = input("Enter PIN Again: ")

    if old_pin == stored_pin:
        new_pin = input("Enter new 4-digit PIN: ")

        if len(new_pin) == 4 and new_pin.isdigit():
            stored_pin = new_pin
            print("PIN changed successfully!")
        else:
            print("Invalid PIN format! Must be 4 digits.")
    else:
        print("Incorrect current PIN!")

while True:
    print("\n--- ATM MENU ---")
    print("1. Check Balance")
    print("2. Deposit Money")
    print("3. Withdraw Money")
    print("4. Change PIN")
    print("5. Exit")

    choice = input("Enter your choice: ")

    if choice == '1':
        if check_pin():
            print("Your Balance is:", balance)
        else:
            print("Incorrect PIN!")

    elif choice == '2':
        if check_pin():
            amount = int(input("Enter amount to deposit: "))
            balance += amount
            print("Deposited successfully. New Balance:", balance)
        else:
            print("Incorrect PIN!")

    elif choice == '3':
        if check_pin():
            amount = int(input("Enter amount to withdraw: "))
            if amount <= balance:
                balance -= amount
                print("Withdraw successful. Remaining Balance:", balance)
            else:
                print("Insufficient Balance!")
        else:
            print("Incorrect PIN!")

    elif choice == '4':
        if check_pin():
            change_pin()
        else:
            print("Incorrect PIN!")

    elif choice == '5':
        print("Thank you for using ATM Simulator!")
        break

    else:
        print("Invalid choice!")
